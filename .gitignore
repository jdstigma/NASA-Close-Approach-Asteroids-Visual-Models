# Data files are committed to the repo (both under 50 MB)
# asteroids_data.csv  — raw NASA CNEOS source
# asteroids_flat.csv  — flattened output (one row per close approach)

# Node
node_modules/
.tmp/
dist/

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# pbiviz build output is ignored, but the published release/ copy is tracked
*.pbiviz
!release/*.pbiviz

# webpack analyzer reports
webpack.statistics.*.html

# Power BI Desktop files (binary, often large)
*.pbix

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
